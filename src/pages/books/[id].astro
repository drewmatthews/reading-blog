---
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import ReadingLayout from '@layouts/ReadingLayout.astro';
import { resolveTheme } from '@lib/theme.ts';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books.map((book) => ({ params: { id: book.id }, props: { book } }));
}
const { book } = Astro.props;
const theme = await resolveTheme(book);
const { Content } = await render(book);

const updates = (await getCollection('updates'))
  .filter((u) => u.data.book.id === book.id)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const fmt = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
---
<ReadingLayout title={book.data.title} theme={theme} backHref="/" backLabel="Bookshelf">
  <div class="hero">
    {book.data.cover && (
      <Image class="hero-cover" src={book.data.cover} alt={book.data.title} widths={[220, 440]} sizes="150px" />
    )}
    <div class="hero-meta">
      <p class="author">{book.data.author}</p>
      <h1>{book.data.title}</h1>
      <div class="stats">
        <span class="stat">📖 {updates.length} update{updates.length === 1 ? '' : 's'}</span>
        <span class="stat">🎧 {book.data.format}</span>
      </div>
    </div>
  </div>

  <div class="intro"><Content /></div>

  <div class="updates-label">Updates</div>
  {updates.length === 0 ? (
    <p class="empty">First update coming soon. ✨</p>
  ) : (
    updates.map((u) => (
      <a class="upd" href={`/updates/${u.id}`}>
        <div class="upd-top"><span class="upd-ch">Ch. {u.data.chapters}</span><span class="upd-date">{fmt(u.data.date)}</span></div>
        <div class="upd-title">{u.data.title}</div>
        <div class="upd-foot">
          {u.data.rating != null && <span>⭐ {u.data.rating}/5</span>}
          {u.data.prediction && <span>🔮 prediction</span>}
        </div>
      </a>
    ))
  )}
</ReadingLayout>

<style>
  .hero { display: flex; gap: 1.3rem; margin-bottom: 1.2rem; align-items: flex-start; }
  .hero-cover { width: 130px; min-width: 130px; height: auto; border-radius: 8px;
    box-shadow: 0 10px 26px rgba(22,38,74,.28); }
  .hero-meta { flex: 1; }
  .author { color: var(--accent-strong); font-size: 0.85rem; margin: 0 0 0.3rem; font-weight: 600; }
  h1 { font-family: var(--font-display); font-weight: 500;
    font-size: 6rem; line-height: 1.0; letter-spacing: var(--display-tracking);
    margin: 0 0 0.7rem; color: var(--text); }
  .stats { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .stat { font-size: 0.68rem; padding: 0.28em 0.7em; border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 16%, transparent); color: var(--accent-strong);
    border: 1px solid color-mix(in srgb, var(--accent) 32%, transparent); }
  .intro { font-family: var(--font-reading); font-size: 1.1rem; line-height: 1.6; color: var(--text);
    border-bottom: 1px solid var(--border); padding-bottom: 1.1rem; margin-bottom: 0.4rem; }
  .updates-label { font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--text-dim); margin: 0.8rem 0 0.2rem; font-weight: 700; }
  .empty { color: var(--text-dim); font-style: italic; padding: 0.6rem 0; }
  .upd { display: block; text-decoration: none; color: inherit; padding: 1rem 0;
    border-bottom: 1px solid var(--border); }
  .upd:hover .upd-title { color: var(--accent-strong); }
  .upd-top { display: flex; justify-content: space-between; }
  .upd-ch { font-size: 0.68rem; color: var(--accent-strong); font-weight: 700; }
  .upd-date { font-size: 0.68rem; color: var(--text-dim); }
  .upd-title { font-family: var(--font-display); font-weight: var(--display-weight);
    font-size: 1.5rem; margin: 0.3rem 0 0.25rem; line-height: 1.15; letter-spacing: var(--display-tracking);
    transition: color .12s; }
  .upd-foot { font-size: 0.68rem; color: var(--text-dim); display: flex; gap: 0.7rem; }
</style>
