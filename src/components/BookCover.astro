---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
interface Props { book: CollectionEntry<'books'>; theme: string; }
const { book, theme } = Astro.props;
---
<a class="cover" href={`/books/${book.id}`} data-theme={theme}>
  {book.data.cover
    ? <Image class="cover-img" src={book.data.cover} alt={book.data.title}
        widths={[240, 480]} sizes="(max-width: 520px) 45vw, 220px" />
    : <div class="cover-fallback"><span class="ct">{book.data.title}</span></div>}
  {book.data.status === 'reading' && <span class="badge">● reading</span>}
</a>

<style>
  .cover { position: relative; display: block; aspect-ratio: 2/3; border-radius: 2px;
    overflow: hidden; text-decoration: none; box-shadow: 0 6px 18px rgba(0,0,0,.14);
    transition: transform .15s ease, box-shadow .15s ease; background: var(--surface-raised); }
  .cover:hover { transform: translateY(-3px); box-shadow: 0 12px 26px rgba(0,0,0,.2); }
  .cover-img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .cover-fallback { height: 100%; padding: 0.8rem 0.7rem; display: flex; align-items: flex-end;
    background: linear-gradient(160deg, var(--surface-raised), var(--surface)); }
  .cover-fallback .ct { font-family: var(--font-display); font-weight: 700; color: var(--text);
    line-height: 1.1; font-size: 0.9rem; }
  .badge { position: absolute; top: 8px; left: 8px; font-size: 0.58rem; font-weight: 700;
    letter-spacing: 0.04em; color: #fff; background: rgba(17,17,17,.82); padding: 0.2em 0.55em;
    border-radius: 2px; }
</style>
