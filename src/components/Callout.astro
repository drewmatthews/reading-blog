---
// A boxed aside / callout. Authored in updates with -= ... =- and converted to
// <Callout>…</Callout> by scripts/build-update.mjs.
---
<aside class="callout"><slot /></aside>

<style>
  aside.callout {
    margin: 1.9rem 0;
    padding: 1rem 1.3rem;
    border: 1px solid var(--border);
    border-left: 4px solid var(--accent);
    border-radius: 6px;
    background: var(--surface-raised);
    font-family: var(--font-reading);
    font-size: 1.05rem;
    line-height: 1.65;
  }
  aside.callout :global(p) { margin: 0; }
  aside.callout :global(p + p) { margin-top: 0.8rem; }
</style>
