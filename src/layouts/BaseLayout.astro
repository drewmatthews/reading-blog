---
import '@styles/global.css';
import FootnotePopover from '@components/FootnotePopover.astro';
interface Props { title: string; theme?: string; }
const { title, theme = 'default' } = Astro.props;
---
<!doctype html>
<html lang="en" data-theme={theme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700;9..144,900&family=Pirata+One&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <main><slot /></main>
    <FootnotePopover />
  </body>
</html>
